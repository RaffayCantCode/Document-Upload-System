# Server Configuration
PORT=5000

# Database Settings
# DB_TYPE supports: sqlite, postgres
DB_TYPE=sqlite
DB_PATH=database.sqlite

# For PostgreSQL, uncomment and set the connection string:
# PG_CONNECTION_STRING=postgresql://user:password@localhost:5432/document_upload

# Upload Limits (in megabytes)
MAX_FILE_SIZE_MB=1

# CORS - comma-separated list of allowed origins (use * for all)
CORS_ORIGINS=*
